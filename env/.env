VITE_APP_TITLE = 'my-poly'
VITE_APP_PORT = 9000

VITE_UNI_APPID = '__UNI__MY_POLY'
VITE_WX_APPID = 'wx41143627eaf3541f'

# 微信开发者工具 CLI 路径，仅当默认安装路径不正确时配置
# macOS 示例：
# WECHAT_DEVTOOLS_CLI_PATH = '/Applications/wechatwebdevtools.app/Contents/MacOS/cli'

VITE_APP_PUBLIC_BASE=/

# 默认后台请求地址（含 /v1 全局前缀）
# 不同命令会按 mode 叠加读取 .env.development / .env.test / .env.production
VITE_SERVER_BASEURL = 'https://api.zequan.club/v1'

# 微信小程序专用（按 envVersion 区分，见 src/utils/index.ts → getEnvBaseUrl）
# 体验版 trial / 正式版 release：代码层强制走 https://api.zequan.club/v1
# 本地 dev:mp 开发版 develop 见 .env.development（127.0.0.1）
VITE_SERVER_BASEURL__WEIXIN_TRIAL = 'https://api.zequan.club/v1'
VITE_SERVER_BASEURL__WEIXIN_RELEASE = 'https://api.zequan.club/v1'

# h5 是否需要配置代理（开发环境建议在 .env.development 中开启）
VITE_APP_PROXY_ENABLE = false
VITE_APP_PROXY_PREFIX = '/api'

VITE_SERVER_BASEURL_SECONDARY = 'https://api.zequan.club/v1'

# 认证模式：nest-prisma-api 使用单 token
VITE_AUTH_MODE = 'single'

VITE_COPY_NATIVE_RES_ENABLE = true
